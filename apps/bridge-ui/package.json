    "@testing-library/svelte": "^5.2.9",
    "@playwright/test": "^1.55.1",
    "@tauri-apps/cli": "^2.8.0",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "jsdom": "^26.1.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
