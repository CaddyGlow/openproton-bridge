{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenProton Bridge UI",
  "version": "0.1.0",
  "identifier": "me.openproton.bridgeui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenProton Bridge",
        "width": 1120,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
